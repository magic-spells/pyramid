{
	"name": "@magic-spells/pyramid",
	"version": "0.1.1",
	"description": "MCP server + CLI for the Pyramid project-management API.",
	"license": "MIT",
	"homepage": "https://github.com/magic-spells/pyramid#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/magic-spells/pyramid.git"
	},
	"bugs": {
		"url": "https://github.com/magic-spells/pyramid/issues"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"cli",
		"pyramid",
		"project-management",
		"task-management"
	],
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"bin": {
		"pyramid": "dist/bin/pyramid.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsx bin/pyramid.ts",
		"test": "vitest run",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepublishOnly": "npm run build"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.0",
		"undici": "^6.19.0",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"prettier": "^3.8.4",
		"tsx": "^4.16.0",
		"typescript": "^5.5.0",
		"vitest": "^4.1.9"
	}
}
